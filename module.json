  "version": "#{VERSION}#",
  "authors": [
    {
      "name": "NickMoline",
      "url": "https://github.com/NickMoline/",
      "discord": "nickmoline",
      "email": "nick@moline.dev"
    }
  ],
  "compatibility": {
    "minimum": "13",
    "maximum": "14",
    "verified": "14"
  },
  "languages": [
    {
      "lang": "en",
